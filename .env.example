# ============================================
# Udaan AI — Environment Variables Example
# Copy this to .env and fill in your values
# ============================================

# Database — SQLite for development
DATABASE_URL="file:./dev.db"

# For production on Vercel, use PostgreSQL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/udaan_ai"

# JWT Secret — generate a strong random string for production
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-strong-jwt-secret-here"

# Google AI Studio API Key
# Get it FREE at: https://aistudio.google.com/
GOOGLE_AI_API_KEY="your-google-ai-api-key-here"

# OpenRouter API Key (Optional — for backup/failover and alternative free models)
# Get a free key at: https://openrouter.ai/
OPENROUTER_API_KEY=""

# Preferred provider: "google" (Google AI Studio) or "openrouter" (OpenRouter)
PREFERRED_PROVIDER="google"
